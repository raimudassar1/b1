  "1": {
    "id": 1,
    "title": "歡迎你來臺灣",
    "dialogues": [
      {
        "title": "Dialogue 1: Welcome to Taiwan!",
        "messages": [
          {
            "speaker": "明華",
            "ch": "請問你是陳月美小姐嗎？",
            "py": "Qǐngwèn nǐ shì Chén Yuèměi xiǎojiě ma?",
            "en": "Excuse me, are you Miss Chen Yuemei?"
          },
          {
            "speaker": "月美",
            "ch": "是的。謝謝你來接我們。",
            "py": "Shìde. Xièxiè nǐ lái jiē wǒmen.",
            "en": "Yes. Thank you for coming to pick us up."
          },
          {
            "speaker": "明華",
            "ch": "不客氣。我是李明華。",
            "py": "Búkèqì. Wǒ shì Lǐ Mínghuá.",
            "en": "You are welcome. I am Li Minghua."
          },
          {
            "speaker": "月美",
            "ch": "這是王先生。",
            "py": "Zhè shì Wáng xiānshēng.",
            "en": "This is Mr. Wang."
          },
          {
            "speaker": "開文",
            "ch": "你好，我姓王，叫開文。",
            "py": "Nǐhǎo, wǒ xìng Wáng, jiào Kāiwén.",
            "en": "How are you? My surname is Wang, my name is Kaiwen."
          },
          {
            "speaker": "明華",
            "ch": "你們好。歡迎你們來臺灣。",
            "py": "Nǐmen hǎo. Huānyíng nǐmen lái Táiwān.",
            "en": "How are you? Welcome to Taiwan."
          }
        ]
      },
      {
        "title": "Dialogue 2: Where are you from?",
        "messages": [
          {
            "speaker": "開文",
            "ch": "李先生，你是臺灣人嗎？",
            "py": "Lǐ xiānshēng, nǐ shì Táiwān rén ma?",
            "en": "Mr. Li, are you Taiwanese?"
          },
          {
            "speaker": "明華",
            "ch": "是，我是臺灣人。王先生，你是哪國人？",
            "py": "Shì, wǒ shì Táiwān rén. Wáng xiānshēng, nǐ shì nǎ guó rén?",
            "en": "Yes, I am Taiwanese. Mr. Wang, what country are you from?"
          },
          {
            "speaker": "開文",
            "ch": "我是美國人。陳小姐，你呢？你是哪國人？",
            "py": "Wǒ shì Měiguó rén. Chén xiǎojiě, nǐ ne? Nǐ shì nǎ guó rén?",
            "en": "I am American. Miss Chen, how about you? What country are you from?"
          },
          {
            "speaker": "月美",
            "ch": "我是越南人。",
            "py": "Wǒ shì Yuènán rén.",
            "en": "I am Vietnamese."
          },
          {
            "speaker": "開文",
            "ch": "李先生，王先生，我們喜歡喝茶。臺灣人呢？",
            "py": "Lǐ xiānshēng, Wáng xiānshēng, wǒmen xǐhuān hē chá. Táiwān rén ne?",
            "en": "Mr. Li, Mr. Wang, we like to drink tea. What about Taiwanese people?"
          },
          {
            "speaker": "明華",
            "ch": "臺灣人也喜歡喝茶。",
            "py": "Táiwān rén yě xǐhuān hē chá.",
            "en": "Taiwanese people also like to drink tea."
          }
        ]
      }
    ],
