  "2": {
    "id": 2,
    "title": "我的家人",
    "dialogues": [
      {
        "title": "Dialogue 1: Who is this?",
        "messages": [
          {
            "speaker": "月美",
            "ch": "明華，這是誰的相片？",
            "py": "Mínghuá, zhè shì shéi de xiàngpiàn?",
            "en": "Minghua, whose picture is this?"
          },
          {
            "speaker": "明華",
            "ch": "這是我家人的相片。",
            "py": "Zhè shì wǒ jiārén de xiàngpiàn.",
            "en": "This is a picture of my family."
          },
          {
            "speaker": "月美",
            "ch": "這個人是誰？",
            "py": "Zhège rén shì shéi?",
            "en": "Who is this person?"
          },
          {
            "speaker": "明華",
            "ch": "這是我爸爸，那是我媽媽。",
            "py": "Zhè shì wǒ bàba, nà shì wǒ māma.",
            "en": "This is my dad, that is my mom."
          },
          {
            "speaker": "月美",
            "ch": "這是你哥哥嗎？",
            "py": "Zhè shì nǐ gēge ma?",
            "en": "Is this your older brother?"
          },
          {
            "speaker": "明華",
            "ch": "不是，他是我弟弟。",
            "py": "Bú shì, tā shì wǒ dìdi.",
            "en": "No, he is my younger brother."
          },
          {
            "speaker": "月美",
            "ch": "那是你妹妹嗎？",
            "py": "Nà shì nǐ mèimei ma?",
            "en": "Is that your younger sister?"
          },
          {
            "speaker": "明華",
            "ch": "是，那是我們妹妹。",
            "py": "Shì, nà shì wǒmen mèimei.",
            "en": "Yes, that is our younger sister."
          }
        ]
      }
    ],
    "vocabulary": [
      {
        "ch": "的",
        "py": "de",
        "en": "possessive particle"
      },
      {
        "ch": "家人",
        "py": "jiārén",
        "en": "family members"
      },
      {
        "ch": "相片",
        "py": "xiàngpiàn",
        "en": "photo, picture"
      },
      {
